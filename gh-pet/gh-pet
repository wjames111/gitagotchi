# --demo: stage an animation on a loop; live refreshes pause so the staged
# state isn't clobbered mid-show (session theater — nothing derived changes)
demo_tick() {
  [[ -z $DEMO ]] && return
  case $DEMO in
    wake)
      local dph=$(( TICK % 64 ))
      if (( dph < 20 )); then
        S[HIB]=1; S[DAYS_QUIET]=95; S[SLEEPING]=0; S[DROWSY]=0
        (( dph == 0 )) && WAKE_UNTIL=-1 FLASH_UNTIL=-1
      elif (( dph == 20 )); then
        S[HIB]=0; S[DAYS_QUIET]=0; S[HOURS_QUIET]=3; S[SLEEPING]=0
        WAKE_UNTIL=$((TICK + 16))
        FLASH_TEXT="${S[NAME]} wakes up ${G_SPARK}"; FLASH_URL=""
        FLASH_UNTIL=$((TICK + 16))
      fi ;;
    eat)
      if (( TICK % 32 == 8 )); then
        EAT_UNTIL=$((TICK + 12))
        FLASH_TEXT="PR #${S[MERGE_NUM]:-482} merged"; FLASH_URL=${S[MERGE_URL]:-}
        FLASH_UNTIL=$((TICK + 8))
        spawn_feed_glee merge
      fi ;;
    celebrate)
      (( TICK % 24 == 8 )) && { CELEB_UNTIL=$((TICK + 8)); spawn_feed_glee shine; } ;;
    hatch)
      if (( TICK % 56 == 8 )); then
        HATCH_UNTIL=$((TICK + 24))
        spawn_friend_glee hatch
        FLASH_TEXT="${S[NAME]:-Pet} hatched ${G_SPARK} welcome!"; FLASH_URL=""
        FLASH_UNTIL=$((TICK + 24))
      fi ;;
    tired)
      S[ENERGY]=15 ;;   # bags under the eyes; below the glasses on an elder
    wired)
      S[ENERGY]=95 ;;   # pupils dilate — big, black, too awake to blink
    curious)
      # scrunched brows + the book stack; the vignette is staged directly so
      # a real low stat (flies/window/belly) can't shove the books offstage
      # visitors (real or a stale PRETEND_VISITORS export) would keep the
      # corner clear for the crowd — the staged show gets the stage alone
      S[CURIOSITY]=90; S[VISITORS]=; VIG_CUR=books ;;
    social)
      S[SOCIAL]=90 ;;   # the tail wags — appendages swish on the half-second
    reviewer)
      S[OUTBOUND7]=5 ;;   # review duty — the pet stands guard with the spear
    skinny)
      S[HUNGER]=10 ;;   # starving pets narrow — hunger wears the silhouette
    chubby)
      S[HUNGER]=95 ;;   # stuffed pets round out
    love)
      S[HAPPINESS]=100 ;;   # rising hearts + the three-heart halo
    fit)
      S[FITNESS]=100 ;;     # the six-pack + idle stretches
    unfit)
      # sweat beads + can barely be bothered to wander (awake, or no idles)
      S[FITNESS]=10 S[HIB]=0 S[DROWSY]=0 S[SLEEPING]=0 S[DAYS_QUIET]=0 ;;
    fetch)
      # the ball game on a loop, no meal first
      if (( TICK % 44 == 8 )); then
        FETCH_UNTIL=$((TICK + 20))
        FLASH_TEXT="PR #482 merged ${G_SPARK} fetch!"; FLASH_URL=""
        FLASH_UNTIL=$((TICK + 10))
      fi
      S[HIB]=0 S[DROWSY]=0 S[SLEEPING]=0 S[DAYS_QUIET]=0 ;;
    stretcher)
      # critical health: the gurney wheels in and the pet hops on, rides
      # until "recovery" (20 healthy ticks — room for the full leap-off +
      # roll-away exit), then the cycle re-arms
      S[HEALTH]=$(( (TICK % 72) < 20 ? 80 : 5 ))
      S[HIB]=0 S[DROWSY]=0 S[SLEEPING]=0 S[DAYS_QUIET]=0 ;;
    sleep)
      S[SLEEPING]=1 S[HIB]=0 S[DROWSY]=0 ;;   # zZz floaters, dimmed screen
    messy)
      # awake pet, CLEAN sweeping 95→10 — watch the mess pile up in steps
      S[HIB]=0 S[DROWSY]=0 S[SLEEPING]=0 S[DAYS_QUIET]=0
      S[CLEAN]=$(( 95 - ((TICK / 16) % 6) * 17 )) ;;
    wise)
      # WISDOM sweeping 30→96 — watch the beard grow: none, stubble, trim, sage
      S[HIB]=0 S[DROWSY]=0 S[SLEEPING]=0 S[DAYS_QUIET]=0
      S[WISDOM]=$(( 30 + ((TICK / 16) % 4) * 22 )) ;;
    night)
      # moon + stars + the moonlit palette (plan.md §11); combine with a
      # season via GITAGOTCHI_PRETEND_MONTH
      GITAGOTCHI_PRETEND_HOUR=23 ;;
    winter)  GITAGOTCHI_PRETEND_MONTH=1  ;;   # snowfall + frosted ground
    spring)  GITAGOTCHI_PRETEND_MONTH=4  ;;   # flowers + fresh grass
    autumn)  GITAGOTCHI_PRETEND_MONTH=10 ;;   # falling leaves + leaf litter
  esac
}

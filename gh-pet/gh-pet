  demo_tick
  if (( RESIZED )); then RESIZED=0; term_size; fi

  if (( COLS < 60 || LINES < 20 )); then
    draw_toosmall "${S[NAME]:-your pet}"
    paint
    read_key 0.25; k=$KEY
    [[ $k == q ]] && break
    continue
  fi

  reap_fetch
  if [[ -z $FIXDIR && -z $FETCH_PID ]]; then
    now=$(date +%s)
    if (( now >= NEXT_REFRESH )); then spawn_refresh
    elif [[ $MODE == friends || $MODE == friend ]] || { [[ $MODE == main ]] && dense_active; }; then
      # fill friend rows in the background; the list never blocks (P4).
      # Visitors (last-hour interactions) ride the same queue so their
      # pets can drop by fully dressed.
      for fl in "${FR_SORTED[@]}" ${S[VISITORS]:-}; do
        (( now - ${FR_FETCHED[$fl]:-0} < TTL_FRIEND )) && continue
        spawn_friend_fetch "$fl"; break
      done
    fi
  fi

  # voice rotates every ~45 s among currently true lines (§5.2)
  if (( TICK - VOICE_AT >= 180 )); then
    voice_pool S "$SELF"
    VI=$(( RANDOM % ${#VPOOL[@]} ))
    VOICE_CUR=${VPOOL[VI]}; VOICE_URL=${VPOOL_URL[VI]:-}
    VOICE_AT=$TICK
  fi
  (( TICK % 20 == 0 )) && vignette_pick S

  # draw current screen
  case $MODE in
    main)
      if dense_active; then
        # animation runs in the pet panel's coordinates (ux-spec §9.1)
        IW=$(( COLS * 54 / 100 - 4 )); SH=9
        anim_update S 1
        draw_dense S 1
      else
        anim_update S 1; draw_main S 1
      fi ;;
    stats)   draw_stats S 1 ;;
    fstats)  draw_stats F 0 ;;
    vitals)   draw_vitals_x "$XSRC" "$XSELF" ;;
    activity) draw_activity_x "$XSRC" "$XSELF" ;;
    feedx)    draw_feed_x "$XSRC" "$XSELF" ;;
    friends)
      if dense_active; then draw_friends_x
      else draw_friends; fi ;;
    friend)
      if dense_active; then
        IW=$(( COLS * 54 / 100 - 4 )); SH=9
        anim_update F 0
        draw_dense F 0
      else
        anim_update F 0; draw_main F 0
      fi ;;
    compare)
      anim_update S 1
      if dense_active; then draw_compare_dense S F
      else draw_compare S F; fi ;;
  esac
  (( HELP )) && overlay_help
  paint

  read_key 0.25; k=$KEY
  [[ -z $k ]] && continue

  if (( HELP )); then
    case $k in "?"|esc|q) HELP=0 ;; esac
    continue
  fi
  case $k in
    "?") HELP=1; continue ;;
    r)
      now=$(date +%s)
      if (( now - LAST_FORCE >= 10 )); then
        LAST_FORCE=$now; NEXT_REFRESH=0
        cache_expire "$TARGET" following   # new follows show up on demand
        FR_FETCHED=()                      # …and the whole crowd re-derives
        if [[ $MODE == friend && -n $FVIEW ]]; then unset "FR_FETCHED[$FVIEW]"; fi
      fi
      continue ;;
  esac

  # Tab inspector: one cursor over the vitals rows, the friends table and
  # the feed entries (Shift+Tab reverses)
  if dense_active && [[ $MODE == main || $MODE == friend ]]; then
    case $k in
      $'\t'|backtab)
        mt_nf=0; [[ $MODE == main ]] && mt_nf=${#FR_SORTED[@]}
        mt_tot=$(( 10 + mt_nf + ${DFEED_VIS:-0} ))
        if [[ $k == $'\t' ]]; then
          MSEL=$(( MSEL + 1 )); (( MSEL >= mt_tot )) && MSEL=-1
        else
          if (( MSEL <= -1 )); then MSEL=$(( mt_tot - 1 )); else MSEL=$(( MSEL - 1 )); fi
        fi
        DSEL=-1 MFEED_SEL=-1
        if (( MSEL >= 0 && MSEL < 10 )); then DSEL=$MSEL
        elif (( MSEL >= 10 && MSEL < 10 + mt_nf )); then SEL_FRIEND=$(( MSEL - 10 ))
        elif (( MSEL >= 10 + mt_nf )); then MFEED_SEL=$(( MSEL - 10 - mt_nf )); fi
        continue ;;
    esac
  fi

  case $MODE in
    main)
      case $k in
        d)
          if dense_active; then DENSE_FORCE=0
          else
            DENSE_FORCE=1
            [[ -z ${S[HIST_HAPPINESS]:-} && -z $FIXDIR ]] && NEXT_REFRESH=0
          fi
          friends_init ;;
        j|down)
          if dense_active && (( ${#FR_SORTED[@]} )); then
            SEL_FRIEND=$(( (SEL_FRIEND + 1) % ${#FR_SORTED[@]} )); fi ;;
        k|up)
          if dense_active && (( ${#FR_SORTED[@]} )); then
            SEL_FRIEND=$(( (SEL_FRIEND + ${#FR_SORTED[@]} - 1) % ${#FR_SORTED[@]} )); fi ;;
        enter)
          if dense_active && (( DSEL >= 0 )); then
            dense_open_sel S
          elif dense_active && (( MFEED_SEL >= 0 )); then
            open_url "$MFEED_URL"
          elif dense_active && (( ${#FR_SORTED[@]} )); then
            fl=${FR_SORTED[SEL_FRIEND]}
            if [[ -n ${FRROW[$fl]:-} ]] && load_state F "$fl"; then
              FVIEW=$fl; MODE=friend
              voice_pool F 0; VOICE_CUR=${VPOOL[0]:-}; VOICE_URL=${VPOOL_URL[0]:-}
            fi
          fi ;;
        esc) DSEL=-1 MSEL=-1 MFEED_SEL=-1 ;;
        c)
          if dense_active && (( ${#FR_SORTED[@]} )); then
            fl=${FR_SORTED[SEL_FRIEND]}
            if [[ -n ${FRROW[$fl]:-} ]] && load_state F "$fl"; then
              CMP_FROM=main; MODE=compare
            fi
          fi ;;
        f) friends_init; MODE=friends; SEL_FRIEND=0; PV_LOGIN=""; MSEL=-1 DSEL=-1 MFEED_SEL=-1 ;;
        s)
          if dense_active; then MODE=vitals XSRC=S XSELF=1 XFROM=main SEL_STAT=0 CSEL=-1 VSEL=0
          else MODE=stats; SEL_STAT=0; fi ;;
        g) dense_active && MODE=activity XSRC=S XSELF=1 XFROM=main ;;
        e) dense_active && MODE=feedx XSRC=S XSELF=1 XFROM=main SEL_FEED=0 ;;
        q)
          # one frame of goodbye, then the terminal is exactly as it was (§5.9)
          printf '\e[2J\e[H'
          for ((i=0; i<LINES/2-1; i++)); do echo; done
          center "(o.o)/  bye!"
          read_key 0.4
          break ;;
      esac ;;
    stats)
      case $k in
        j|down) SEL_STAT=$(( (SEL_STAT + 1) % 10 )) ;;
        k|up)   SEL_STAT=$(( (SEL_STAT + 9) % 10 )) ;;
        enter)  stat_detail_info S "$SEL_STAT"; open_url "$D_URL" ;;
        esc|q|s) MODE=main ;;
      esac ;;
    fstats)
      case $k in
        j|down) SEL_STAT=$(( (SEL_STAT + 1) % 10 )) ;;
        k|up)   SEL_STAT=$(( (SEL_STAT + 9) % 10 )) ;;
        enter)  stat_detail_info F "$SEL_STAT"; open_url "$D_URL" ;;
        esc|q|s) MODE=friend ;;
      esac ;;
    friends)
      local_n=${#FR_SORTED[@]}
      case $k in
        j|down) (( local_n )) && SEL_FRIEND=$(( (SEL_FRIEND + 1) % local_n )) ;;
        k|up)   (( local_n )) && SEL_FRIEND=$(( (SEL_FRIEND + local_n - 1) % local_n )) ;;
        enter)
          if (( local_n )); then
            fl=${FR_SORTED[SEL_FRIEND]}
            if [[ -n ${FRROW[$fl]:-} ]] && load_state F "$fl"; then
              FVIEW=$fl; MODE=friend
              voice_pool F 0; VOICE_CUR=${VPOOL[0]:-}; VOICE_URL=${VPOOL_URL[0]:-}
            fi
          fi ;;
        c)
          if (( local_n )); then
            fl=${FR_SORTED[SEL_FRIEND]}
            if [[ -n ${FRROW[$fl]:-} ]] && load_state F "$fl"; then
              CMP_FROM=friends; MODE=compare
            fi
          fi ;;
        esc|q) MODE=main; voice_pool S "$SELF"; VOICE_CUR=${VPOOL[0]:-}; VOICE_URL=${VPOOL_URL[0]:-} ;;
      esac ;;
    vitals)
      # one cursor: rows 0-9 run down the list, 10-18 continue through the
      # composition rows; jk/arrows/tab all move it, ←→ jump between panels
      vn=10; (( VX_TWO )) && vn=19
      case $k in
        j|down|$'\t') VSEL=$(( (VSEL + 1) % vn )); vx_sel_sync ;;
        k|up|backtab)  VSEL=$(( (VSEL + vn - 1) % vn )); vx_sel_sync ;;
        right) (( VX_TWO )) && (( VSEL < 10 )) && { vx_jump_right; vx_sel_sync; } ;;
        left)  (( VSEL >= 10 )) && { vx_jump_left; vx_sel_sync; } ;;
        enter)
          if (( CSEL >= 0 )); then
            vx_stat_url "$XSRC" "${VX_COMP_NAMES[CSEL]}"; open_url "$VXURL"
          else
            stat_detail_info "$XSRC" "$SEL_STAT"; open_url "$D_URL"
          fi ;;
        esc|q|s) MODE=$XFROM ;;
      esac ;;
    activity)
      case $k in
        $'\t')   act_cycle_range "$XSRC" 1 ;;
        backtab) act_cycle_range "$XSRC" -1 ;;
        esc|q|g) MODE=$XFROM ;;
      esac ;;
    feedx)
      case $k in
        [1-7]) FEED_FILTER=$((k - 1)); SEL_FEED=0 ;;
        j|down) (( FEEDX_N )) && SEL_FEED=$(( (SEL_FEED + 1) % FEEDX_N )) ;;
        k|up)   (( FEEDX_N )) && SEL_FEED=$(( (SEL_FEED + FEEDX_N - 1) % FEEDX_N )) ;;
        enter)  open_url "$FEEDX_SEL_URL" ;;
        esc|q|e) MODE=$XFROM ;;
      esac ;;
    friend)
      case $k in
        s)
          if dense_active; then MODE=vitals XSRC=F XSELF=0 XFROM=friend SEL_STAT=0 CSEL=-1 VSEL=0
          else MODE=fstats; SEL_STAT=0; fi ;;
        g) dense_active && MODE=activity XSRC=F XSELF=0 XFROM=friend ;;
        e) dense_active && MODE=feedx XSRC=F XSELF=0 XFROM=friend SEL_FEED=0 ;;
        c) CMP_FROM=friend; MODE=compare ;;
        enter)
          if dense_active && (( DSEL >= 0 )); then dense_open_sel F
          elif dense_active && (( MFEED_SEL >= 0 )); then open_url "$MFEED_URL"; fi ;;
        esc|q)
          if (( DSEL >= 0 || MFEED_SEL >= 0 )); then DSEL=-1 MSEL=-1 MFEED_SEL=-1
          else
            MODE=friends; voice_pool S "$SELF"; VOICE_CUR=${VPOOL[0]:-}; VOICE_URL=${VPOOL_URL[0]:-}
          fi ;;
      esac ;;
    compare)
      case $k in
        $'\t')
          # ↹ cycles the rivalry through the friends list, skipping unfetched rows
          local_n=${#FR_SORTED[@]}
          local_try=0
          while (( local_n && local_try < local_n )); do
            SEL_FRIEND=$(( (SEL_FRIEND + 1) % local_n ))
            fl=${FR_SORTED[SEL_FRIEND]}
            if [[ $fl != "${F[LOGIN]:-}" && -n ${FRROW[$fl]:-} ]] && load_state F "$fl"; then break; fi
            local_try=$((local_try + 1))
          done ;;
        enter)
          FVIEW=${F[LOGIN]}; MODE=friend
          [[ $CMP_FROM == quit ]] && CMP_FROM=main
          voice_pool F 0; VOICE_CUR=${VPOOL[0]:-}; VOICE_URL=${VPOOL_URL[0]:-} ;;
        s)
          # snapshot to stdout: drop out of the alt screen for a beat and print
          # this exact frame as plain text — it waits in scrollback after quit
          tput rmcup 2>/dev/null
          for l in "${SCREEN[@]}"; do printf '%s\n' "$l"; done | strip_ansi
          tput smcup 2>/dev/null; tput civis 2>/dev/null ;;
        esc|q)
          if [[ $CMP_FROM == quit ]]; then break; fi
          MODE=$CMP_FROM ;;
      esac ;;
  esac
done

exit 0
